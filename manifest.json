{
  "manifest_version": 3,
  "name": "WhatsApp Reader",
  "version": "1.0.0",
  "description": "Reads incoming WhatsApp Web messages aloud using text-to-speech.",
  "permissions": ["storage"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WhatsApp Reader"
  }
}
